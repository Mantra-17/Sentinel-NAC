# =============================================================
# Sentinel-NAC: Environment Configuration Example
# File: config/.env.example
# Purpose: Copy this to config/.env and fill in your values
# WARNING: Never commit .env to version control
# =============================================================

# ---- MySQL Database ----
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=sentinel_nac
DB_USER=sentinel_user
DB_PASSWORD=change_me_strong_password

# ---- Network Scanner ----
# Network interface to listen on (e.g. eth0, wlan0, en0)
SCAN_INTERFACE=wlan0
# Target subnet in CIDR notation (your private lab network)
SCAN_TARGET=192.168.1.0/24
# Seconds between active ARP sweeps (passive sniffing runs continuously)
SCAN_INTERVAL=10

# ---- Policy Engine ----
# Status given to brand new devices: UNKNOWN or QUARANTINED
DEFAULT_NEW_DEVICE_STATUS=QUARANTINED

# ---- Enforcement Mode ----
# Options: simulation | firewall | denylist
# Use 'simulation' for demo environments where root access is unavailable
ENFORCEMENT_MODE=simulation

# ---- Email Alerts (SMTP) ----
ALERT_EMAIL_ENABLED=true
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=sentinel-nac@lab.local
ALERT_RECIPIENT=admin@lab.local

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/sentinel_nac.log

# ---- Report Generation ----
REPORT_OUTPUT_DIR=reports/output
