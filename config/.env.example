# ---- Database ----
# Replace with your actual PostgreSQL connection string
# Format: postgresql://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL="postgresql://user:password@localhost:5432/sentinel_nac"

# ---- Network Scanner ----
# Network interface to listen on (e.g. eth0, wlan0, en0)
SCAN_INTERFACE=wlan0
# Target subnet in CIDR notation
SCAN_TARGET=192.168.1.0/24
# Seconds between active ARP sweeps
SCAN_INTERVAL=10

# ---- Policy Engine ----
# Default status for brand new devices: UNKNOWN or QUARANTINED
DEFAULT_NEW_DEVICE_STATUS=QUARANTINED

# ---- Enforcement Mode ----
# Options: simulation | firewall | denylist | portal
ENFORCEMENT_MODE=simulation

# ---- Portal Settings ----
# Name displayed on the captive portal page (avoid using real names in production)
SYSTEM_ADMIN_NAME=System Administrator

# ---- Email Alerts (SMTP) ----
ALERT_EMAIL_ENABLED=false
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_password
SMTP_FROM=sentinel-nac@lab.local
ALERT_RECIPIENT=admin@lab.local

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FILE=logs/sentinel_nac.log

# ---- Report Generation ----
REPORT_OUTPUT_DIR=reports/output
